# Backend runtime
NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://postgres:your-password@thomas.proxy.rlwy.net:44250/railway
JWT_ACCESS_SECRET=generate-a-long-random-secret
JWT_REFRESH_SECRET=generate-a-different-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
CORS_ORIGIN=https://your-backend.up.railway.app,http://localhost:3000,http://127.0.0.1:3000,http://localhost:4000,http://127.0.0.1:4000,http://localhost:8080
STORAGE_ROOT=storage
SEED_ADMIN_PHONE=07701234567
SEED_ADMIN_PASSWORD=12345678
SEED_ADMIN_NAME=Admin User

# Flutter override used with:
# flutter run --dart-define=API_BASE_URL=http://127.0.0.1:4000
API_BASE_URL=http://127.0.0.1:4000

# Optional native PostgreSQL helper override for backend/scripts/local-postgres.ps1
PG_BIN=C:\Program Files\PostgreSQL\18\bin
